+func TestUserPreferences_ModuleSpecifierPreferences_EffectStyle(t *testing.T) {
+	t.Parallel()
+
+	p := &UserPreferences{
+		ImportModuleSpecifierPreference: modulespecifiers.ImportModuleSpecifierPreferenceNonRelative,
+		ImportModuleSpecifierEnding:     modulespecifiers.ImportModuleSpecifierEndingPreferenceIndex,
+		AutoImportSpecifierExcludeRegexes: []string{
+			"^node:",
+		},
+	}
+	effectStyle := modulespecifiers.EffectAutoImportStylePreferences{
+		NamespaceImportPackages: []string{"effect"},
+		BarrelImportPackages:    []string{"@effect/schema"},
+		ImportAliases: map[string]string{
+			"effect": "Fx",
+		},
+		FollowTopLevelReexports: true,
+	}
+
+	got := p.ModuleSpecifierPreferences(effectStyle)
+	if got.ImportModuleSpecifierPreference != modulespecifiers.ImportModuleSpecifierPreferenceNonRelative {
+		t.Fatalf("ImportModuleSpecifierPreference = %v, want %v", got.ImportModuleSpecifierPreference, modulespecifiers.ImportModuleSpecifierPreferenceNonRelative)
+	}
+	if got.ImportModuleSpecifierEnding != modulespecifiers.ImportModuleSpecifierEndingPreferenceIndex {
+		t.Fatalf("ImportModuleSpecifierEnding = %v, want %v", got.ImportModuleSpecifierEnding, modulespecifiers.ImportModuleSpecifierEndingPreferenceIndex)
+	}
+	if !reflect.DeepEqual(got.AutoImportSpecifierExcludeRegexes, []string{"^node:"}) {
+		t.Fatalf("AutoImportSpecifierExcludeRegexes = %#v, want %#v", got.AutoImportSpecifierExcludeRegexes, []string{"^node:"})
+	}
+	if !reflect.DeepEqual(got.EffectAutoImportStyle, effectStyle) {
+		t.Fatalf("EffectAutoImportStyle = %#v, want %#v", got.EffectAutoImportStyle, effectStyle)
+	}
+}
